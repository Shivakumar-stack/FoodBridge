# FoodBridge Backend Configuration
# Copy this file to .env and update the values

# ================================
# Application Settings
# ================================
NODE_ENV=development
PORT=5000
DEMO_MODE=false

# ================================
# Database Configuration
# ================================
# Local MongoDB
MONGO_URI=mongodb://localhost:27017/foodbridge

# MongoDB Atlas (Production)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/foodbridge

# Optional alias used by some maintenance scripts
MONGODB_URI=

# ================================
# JWT Configuration
# ================================
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_ME
JWT_EXPIRE=7d

# ================================
# Client Configuration
# ================================
# Frontend URL for CORS
CLIENT_URL=http://localhost:5500

# ================================
# Geocoding Configuration (Optional)
# ================================
GEOCODE_DEFAULT_COUNTRY=India
GEOCODE_USER_AGENT=FoodBridge/1.0 (support@foodbridge.local)
GEOCODE_LOOKUP_MODE=fallback

# ================================
# Logging Configuration
# ================================
LOG_LEVEL=info

# ================================
# Session Secret (REQUIRED)
# ================================
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_ME

# ================================
# Email Configuration (Ethereal for Dev)
# ================================
# Create a free test account at https://ethereal.email/
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=your-ethereal-user@ethereal.email
EMAIL_PASS=your-ethereal-password
EMAIL_FROM=noreply@foodbridge.com

# ================================
# Cloudinary Configuration (Optional - Image Uploads)
# ================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ================================
# Social Auth Configuration (Optional)
# ================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:5000/api/auth/facebook/callback

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=http://localhost:5000/api/auth/apple/callback

# ================================
# Vision API Configuration (Optional)
# ================================
HUGGINGFACE_API_KEY=
