{
  "name": "foodbridge",
  "version": "1.0.0",
  "description": "FoodBridge - Food Donation Platform",
  "scripts": {
    "start:backend": "node backend/server.js",
    "start:frontend": "npm run serve --prefix frontend",
    "start": "node backend/server.js",
    "build": "npm install --prefix frontend && npm run build:css --prefix frontend",
    "start:all": "npm-run-all --parallel start:backend start:frontend",
    "demo": "powershell -ExecutionPolicy Bypass -File scripts/start-demo.ps1",
    "dev:backend": "nodemon backend/server.js -- --port=5001",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "prod": "cross-env NODE_ENV=production node backend/server.js",
    "test": "node scripts/run-tests.js",
    "test:watch": "node scripts/run-tests.js",
    "test:jest": "jest --passWithNoTests --detectOpenHandles --runInBand",
    "seed": "node scripts/seedDatabase.js",
    "seed:demo": "node scripts/seed_demo_population.js",
    "lint": "eslint . --ext .js --report-unused-disable-directives",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\""
  },
  "keywords": [
    "food-donation",
    "ngo",
    "volunteer",
    "express",
    "mongodb"
  ],
  "author": "FoodBridge Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.18.0",
    "express-validator": "^7.3.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.1",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^2.2.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "socket.io": "^4.8.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/frontend/"
    ]
  }
}
